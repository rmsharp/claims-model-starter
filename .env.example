# Model Project Constructor — environment variable template
#
# Copy this file to `.env` (which is git-ignored) and fill in the values
# appropriate for your deployment. The orchestrator reads these via
# `OrchestratorSettings.from_env()` — see `src/model_project_constructor/
# orchestrator/config.py` for the loader and `OPERATIONS.md` for the full
# runbook.
#
# None of these values have safe defaults for credentials. The app will
# refuse to start any live-host run without an explicit token.

# -----------------------------------------------------------------------
# Host selection
# -----------------------------------------------------------------------
# Which git host the Website Agent targets. One of: gitlab, github.
MPC_HOST=gitlab

# API base URL. If unset, defaults to the public host for the selected
# platform (https://gitlab.com or https://api.github.com). Set this to
# your enterprise instance URL for self-hosted deployments.
#MPC_HOST_URL=https://gitlab.example.com

# -----------------------------------------------------------------------
# Host credentials (exactly one is required for a live run)
# -----------------------------------------------------------------------
# GitLab personal access token with `api` scope + create_project
# permission on MPC_NAMESPACE.
#GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitHub personal access token (classic or fine-grained) with `repo`
# scope on the target owner/org.
#GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------
# Anthropic (required by agents that call Claude)
# -----------------------------------------------------------------------
# Required by: Intake Agent (web UI + real interviews), Data Agent (QC
# generation), any runner wiring that invokes Anthropic directly.
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------
# Orchestrator runtime
# -----------------------------------------------------------------------
# Root directory for the checkpoint store. Each run creates a
# subdirectory named after its `run_id`. Defaults to
# `./.orchestrator/checkpoints`.
#MPC_CHECKPOINT_DIR=/var/lib/mpc/checkpoints

# Stdlib logging level for the orchestrator namespace. One of:
# DEBUG, INFO, WARNING, ERROR, CRITICAL. Defaults to INFO.
#MPC_LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Intake Agent web UI (optional — only needed by the FastAPI UI)
# -----------------------------------------------------------------------
# Path to the SQLite file where live interview sessions are checkpointed.
# Defaults to `./intake_sessions.db` in the working directory.
#INTAKE_DB_PATH=/var/lib/mpc/intake_sessions.db
